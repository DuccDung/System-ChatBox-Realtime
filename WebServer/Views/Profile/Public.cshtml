@model WebServer.Dtos.UserDto

@{
    ViewData["Title"] = "Hồ sơ công khai";

    string FormatDateOnly(DateOnly? dob)
    {
        if (dob == null) return "Chưa cập nhật";
        return $"{dob.Value.Day} tháng {dob.Value.Month}, {dob.Value.Year}";
    }

    string FormatGender(byte? gender)
    {
        if (gender == null) return "Chưa cập nhật";
        return gender.Value switch
        {
            0 => "Nữ",
            1 => "Nam",
            2 => "Khác",
            _ => "Chưa cập nhật"
        };
    }

    string SafePhoto(string? photo) => string.IsNullOrWhiteSpace(photo) ? Url.Content("~/assets/images/avatar-default.png") : photo!;
    string SafeCover(string? cover) => string.IsNullOrWhiteSpace(cover) ? Url.Content("~/assets/images/cover_default.jpg") : cover!;
    string AvatarBackground(string? photo) => $"background-image: url('{SafePhoto(photo)}'), url('{Url.Content("~/assets/images/avatar-default.png")}')";
    string CoverBackground(string? cover) => $"background-image: url('{SafeCover(cover)}'), url('{Url.Content("~/assets/images/cover_default.jpg")}')";
    string SafeBio(string? bio) => string.IsNullOrWhiteSpace(bio) ? "Chưa có giới thiệu" : bio!;
}

<!-- Profile Header -->
<div class="profile-header public"
     style="@CoverBackground(Model.PhotoBackground)">
    <div class="profile-header-overlay"></div>
</div>

<div class="profile-container">
    <!-- Avatar và thông tin cơ bản -->
    <div class="profile-main-card public">
        <div class="profile-avatar-container">
            <div class="profile-avatar"
                 style="@AvatarBackground(Model.PhotoPath)"></div>
        </div>

        <div class="profile-info">
            <h1 class="profile-name">@(string.IsNullOrWhiteSpace(Model.AccountName) ? "Người dùng" : Model.AccountName)</h1>
            <p class="profile-bio">@SafeBio(Model.Bio)</p>
            <div class="profile-status">
                <span class="profile-status-indicator offline"></span>
                <span class="profile-status-text">Offline</span>
            </div>
        </div>

        <div class="profile-actions public">
            <a href="/Auth/Login" class="profile-btn profile-btn-primary">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                Nhắn tin
            </a>
            <button class="profile-btn profile-btn-secondary" type="button" id="btnFollow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <line x1="20" y1="8" x2="20" y2="14"></line>
                    <line x1="23" y1="11" x2="17" y2="11"></line>
                </svg>
                Theo dõi
            </button>
        </div>
    </div>

    <!-- Thông tin chi tiết -->
    <div class="profile-section-card">
        <h2 class="profile-section-title">Giới thiệu</h2>
        <div class="profile-details">
            <div class="profile-detail-item">
                <span class="profile-detail-label">Ngày sinh</span>
                <span class="profile-detail-value">@FormatDateOnly(Model.DateOfBirth)</span>
            </div>
            <div class="profile-detail-item">
                <span class="profile-detail-label">Giới tính</span>
                <span class="profile-detail-value">@FormatGender(Model.Gender)</span>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/pages/profile/main.css" />
<script type="module" src="~/js/pages/profile/view.js"></script>
