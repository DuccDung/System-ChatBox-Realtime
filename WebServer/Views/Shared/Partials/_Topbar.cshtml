@using WebServer.Dtos
@{
    var user = ViewBag.User as UserDto;
    var defaultAvatarUrl = Url.Content("~/assets/images/avatar-default.png");

    string SafeAssetUrl(string? url, string fallback)
    {
        if (string.IsNullOrWhiteSpace(url)) return fallback;
        return url.StartsWith("~/", StringComparison.Ordinal) ? Url.Content(url) : url;
    }

    var avatarUrl = SafeAssetUrl(user?.PhotoPath, defaultAvatarUrl);
}
<style>

    /* ✅ Avatar dropdown */
    .avatar-menu {
        position: relative;
    }

    .avatar {
        width: 40px;
        height: 40px;
        border: 0;
        background: transparent;
        border-radius: 999px;
        overflow: hidden;
        cursor: pointer;
        padding: 0;
    }

        .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .avatar-dropdown {
        position: absolute;
        top: calc(100% + 10px);
        right: 0;
        min-width: 200px;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 14px 40px rgba(0, 0, 0, 0.18);
        overflow: hidden;
        z-index: 9999;
        border: 1px solid rgba(0, 0, 0, 0.06);
    }

    .avatar-dropdown__item {
        display: block;
        width: 100%;
        padding: 12px 14px;
        text-decoration: none;
        background: transparent;
        border: 0;
        text-align: left;
        cursor: pointer;
        font-size: 14px;
        color: #111;
    }

        .avatar-dropdown__item:hover {
            background: rgba(0, 0, 0, 0.05);
        }

    .avatar-dropdown__danger {
        color: #d11a2a;
    }
</style>
<div class="topbar">
    <!-- Left: Logo + Search -->
    <div class="top-left">
        <a class="brand" id="backBtn">
            <img src="~/assets/icons/facebook.svg" alt="" />
        </a>
        <div class="searchbar-top">
            <img src="~/assets/icons/search.svg" alt="" />
            <input type="text" placeholder="Tìm kiếm trên Facebook" />
        </div>
    </div>

    <!-- Center: Main nav -->
    <div class="top-center"></div>

    <!-- Right: Options -->
    <div class="top-right">
        <button class="icon-btn">
            <img src="~/assets/icons/grid.svg" alt="" />
        </button>
        <div class="notification-menu" id="notificationMenu">
            <button class="icon-btn notification-btn"
                    type="button"
                    id="notificationBtn"
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-controls="notificationPopup"
                    title="Thông báo">
                <img src="~/assets/icons/bell.svg" alt="" />
                <span class="notification-badge" id="notificationBadge" hidden>0</span>
            </button>

            <section class="notification-popup"
                     id="notificationPopup"
                     aria-label="Thông báo"
                     hidden>
                <div class="notification-popup__header">
                    <div>
                        <h2>Thông báo</h2>
                        <p id="notificationSummary">Đang tải...</p>
                    </div>
                    <button class="notification-popup__mark-all"
                            type="button"
                            id="notificationMarkAllBtn">
                        Đánh dấu đã đọc
                    </button>
                </div>

                <div class="notification-popup__tabs" role="tablist" aria-label="Bộ lọc thông báo">
                    <button class="notification-popup__tab is-active"
                            type="button"
                            data-notification-filter="all">
                        Tất cả
                    </button>
                    <button class="notification-popup__tab"
                            type="button"
                            data-notification-filter="unread">
                        Chưa đọc
                    </button>
                </div>

                <div class="notification-popup__list" id="notificationList">
                    <div class="notification-popup__state">Đang tải thông báo...</div>
                </div>
            </section>
        </div>
        @* <button class="avatar"> *@
        @*     <img src="@user.PhotoPath" alt="" /> *@
        @* </button> *@
        <div class="avatar-menu">
            <button class="avatar"
                    id="avatarBtn"
                    aria-haspopup="true"
                    aria-expanded="false">
                <img src="@avatarUrl"
                     alt="Ảnh đại diện"
                     onerror="this.onerror=null;this.src='@defaultAvatarUrl';" />
            </button>

            <div class="avatar-dropdown" id="avatarDropdown" hidden>
                <a class="avatar-dropdown__item" href="/Profile/Me">Hồ sơ cá nhân</a>
                <button class="avatar-dropdown__item avatar-dropdown__danger"
                        id="logoutBtn"
                        type="button">
                    Đăng xuất
                </button>
            </div>
        </div>
    </div> 

</div>
